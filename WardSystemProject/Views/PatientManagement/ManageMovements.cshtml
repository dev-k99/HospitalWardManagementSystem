@model IEnumerable<WardSystemProject.Models.PatientMovement>

@{
    var patient = ViewBag.Patient as WardSystemProject.Models.Patient;
    ViewData["Title"] = "Patient Movements";
    Layout = "_Layout";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">
        Patient: <strong>@patient?.FirstName @patient?.LastName</strong>
        &mdash; Ward: <strong>@(patient?.Ward?.Name ?? "N/A")</strong>
    </p>
    <a href="@Url.Action("PatientFolder", new { id = patient?.Id })" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Folder
    </a>
</div>

<!-- Record new movement -->
<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-arrow-left-right"></i> Record New Movement</h5>
    </div>
    <div class="card-body">
        <form asp-action="ManageMovements" asp-route-id="@patient?.Id" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-medium">From Ward</label>
                    <select name="FromWardId" class="form-select" asp-items="ViewBag.FromWards" required>
                        <option value="">Select ward</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-medium">To Ward / Location</label>
                    <select name="ToWardId" class="form-select" asp-items="ViewBag.ToWards" required>
                        <option value="">Select ward</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-medium">Movement Type</label>
                    <select name="MovementType" class="form-select" required>
                        <option value="Ward Transfer">Ward Transfer</option>
                        <option value="Theatre">Theatre</option>
                        <option value="X-Ray">X-Ray</option>
                        <option value="Return">Return</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-medium">Date &amp; Time</label>
                    <input type="datetime-local" name="MovementDate" class="form-control"
                           value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-save"></i> Record
                    </button>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col">
                    <label class="form-label fw-medium">Reason / Notes <span class="text-muted">(optional)</span></label>
                    <input type="text" name="MovementReason" class="form-control"
                           placeholder="e.g. Scheduled surgery, routine X-ray, ward capacity..." maxlength="500" />
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Movement history -->
<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Movement History</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date &amp; Time</th>
                        <th>Type</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Reason</th>
                        <th>Recorded By</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No movements recorded yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var m in Model)
                        {
                            <tr>
                                <td>@m.MovementDate.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @(m.MovementType == "Theatre" ? "bg-danger" :
                                                         m.MovementType == "X-Ray"   ? "bg-warning text-dark" :
                                                         m.MovementType == "Return"  ? "bg-success" : "bg-secondary")">
                                        @m.MovementType
                                    </span>
                                </td>
                                <td>@(m.FromWard?.Name ?? "—")</td>
                                <td>@(m.ToWard?.Name ?? "—")</td>
                                <td>@(m.MovementReason ?? "—")</td>
                                <td>@(m.RecordedBy ?? "—")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
