@model WardSystemProject.ViewModels.AdmitPatientViewModel

@{
    ViewData["Title"] = "Admit Patient";
    Layout = "_Layout";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header text-white" style="background: linear-gradient(135deg, #2563eb, #1d4ed8); border-radius: var(--card-radius) var(--card-radius) 0 0;">
        <h5 class="mb-0"><i class="bi bi-hospital"></i> Patient Admission Form</h5>
    </div>
    <div class="card-body">
        <form asp-action="Admit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Personal Information -->
            <div class="form-section mb-4 p-3 border rounded">
                <h5 class="mb-3 pb-2 border-bottom text-primary"><i class="bi bi-person"></i> Personal Information</h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label fw-medium">First Name</label>
                        <input asp-for="FirstName" class="form-control" required />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label fw-medium">Last Name</label>
                        <input asp-for="LastName" class="form-control" required />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="DateOfBirth" class="form-label fw-medium">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" required />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Gender" class="form-label fw-medium">Gender</label>
                        <select asp-for="Gender" class="form-select" required>
                            <option value="">Select Gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="ContactNumber" class="form-label fw-medium">Contact Number</label>
                        <input asp-for="ContactNumber" class="form-control" />
                        <span asp-validation-for="ContactNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Address" class="form-label fw-medium">Address</label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="EmergencyContact" class="form-label fw-medium">Emergency Contact</label>
                        <input asp-for="EmergencyContact" class="form-control" />
                        <span asp-validation-for="EmergencyContact" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EmergencyContactNumber" class="form-label fw-medium">Emergency Contact Number</label>
                        <input asp-for="EmergencyContactNumber" class="form-control" />
                        <span asp-validation-for="EmergencyContactNumber" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="NextOfKin" class="form-label fw-medium">Next of Kin</label>
                        <input asp-for="NextOfKin" class="form-control" />
                        <span asp-validation-for="NextOfKin" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NextOfKinContact" class="form-label fw-medium">Next of Kin Contact</label>
                        <input asp-for="NextOfKinContact" class="form-control" />
                        <span asp-validation-for="NextOfKinContact" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Medical Information -->
            <div class="form-section mb-4 p-3 border rounded">
                <h5 class="mb-3 pb-2 border-bottom text-primary"><i class="bi bi-heart-pulse"></i> Medical Information</h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="BloodType" class="form-label fw-medium">Blood Type</label>
                        <select asp-for="BloodType" class="form-select">
                            <option value="">Select Blood Type</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                        </select>
                        <span asp-validation-for="BloodType" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ChronicMedications" class="form-label fw-medium">Chronic Medications</label>
                        <textarea asp-for="ChronicMedications" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="ChronicMedications" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="MedicalHistory" class="form-label fw-medium">Medical History</label>
                        <textarea asp-for="MedicalHistory" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="MedicalHistory" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Allergies" class="form-label fw-medium">Allergies</label>
                        <textarea asp-for="Allergies" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Allergies" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Admission Details -->
            <div class="form-section mb-4 p-3 border rounded">
                <h5 class="mb-3 pb-2 border-bottom text-primary"><i class="bi bi-clipboard2-pulse"></i> Admission Details</h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="AdmissionReason" class="form-label fw-medium">Admission Reason</label>
                        <textarea asp-for="AdmissionReason" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="AdmissionReason" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AdmissionDate" class="form-label fw-medium">Admission Date</label>
                        <input asp-for="AdmissionDate" type="datetime-local" class="form-control"
                               value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" readonly />
                        <span asp-validation-for="AdmissionDate" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Assignments -->
            <div class="form-section mb-4 p-3 border rounded">
                <h5 class="mb-3 pb-2 border-bottom text-primary"><i class="bi bi-building"></i> Assignments</h5>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="WardId" class="form-label fw-medium">Ward</label>
                        <select asp-for="WardId" class="form-select" asp-items="ViewBag.WardId">
                            <option value="">Select Ward</option>
                        </select>
                        <span asp-validation-for="WardId" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="BedId" class="form-label fw-medium">Bed</label>
                        <select asp-for="BedId" class="form-select" asp-items="ViewBag.BedId">
                            <option value="">Select Bed</option>
                        </select>
                        <span asp-validation-for="BedId" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="AssignedDoctorId" class="form-label fw-medium">Assigned Doctor</label>
                        <select asp-for="AssignedDoctorId" class="form-select" asp-items="ViewBag.AssignedDoctorId">
                            <option value="">Select Doctor</option>
                        </select>
                        <span asp-validation-for="AssignedDoctorId" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="text-end">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary me-2">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Admit Patient
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
