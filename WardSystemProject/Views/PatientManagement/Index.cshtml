@model IEnumerable<WardSystemProject.Models.Patient>

@{
    ViewData["Title"] = "Manage Patients";
    Layout = "_Layout";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">List of all admitted patients</p>
    <a href="@Url.Action("Admit")" class="btn btn-success">
        <i class="bi bi-person-plus"></i> Admit New Patient
    </a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form action="@Url.Action("Search")" method="get" id="searchForm">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control" id="query" name="query"
                       placeholder="Search by name or contact number" />
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-list-ul"></i> Patients</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0" id="patientsTable">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Age</th>
                        <th>Gender</th>
                        <th>Ward</th>
                        <th>Bed</th>
                        <th>Doctor</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-4 text-muted">No patients found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var patient in Model)
                        {
                            <tr>
                                <td>@patient.Id</td>
                                <td>@patient.FirstName @patient.LastName</td>
                                <td>@(DateTime.Now.Year - patient.DateOfBirth.Year)</td>
                                <td>@patient.Gender</td>
                                <td>@(patient.Ward?.Name ?? "N/A")</td>
                                <td>@(patient.Bed?.BedNumber ?? "N/A")</td>
                                <td>@(patient.AssignedDoctor?.FullName ?? "N/A")</td>
                                <td>
                                    <span class="badge @(patient.PatientStatus == "Admitted" ? "bg-success" : "bg-secondary")">
                                        @patient.PatientStatus
                                    </span>
                                </td>
                                <td>
                                    <a href="@Url.Action("DetailsPatient", new { id = patient.Id })" class="btn btn-sm btn-outline-info" title="Details"><i class="bi bi-eye"></i></a>
                                    <a href="@Url.Action("EditPatient", new { id = patient.Id })" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a href="@Url.Action("PatientFolder", new { id = patient.Id })" class="btn btn-sm btn-outline-primary" title="Patient Folder"><i class="bi bi-folder"></i></a>
                                    <a href="@Url.Action("Discharge", new { id = patient.Id })" class="btn btn-sm btn-outline-secondary" title="Discharge"><i class="bi bi-box-arrow-right"></i></a>
                                    <a href="@Url.Action("ManageConditions", new { id = patient.Id })" class="btn btn-sm btn-outline-warning" title="Manage Conditions"><i class="bi bi-heart-pulse"></i></a>
                                    <a asp-action="ManageAllergies" asp-route-Id="@patient.Id" class="btn btn-sm btn-outline-info" title="Manage Allergies"><i class="bi bi-shield-exclamation"></i></a>
                                    <a href="@Url.Action("DeletePatient", new { id = patient.Id })" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('query').addEventListener('keyup', function () {
            if (this.value.length >= 2 || this.value.length === 0) {
                this.closest('form').submit();
            }
        });
    </script>
}
